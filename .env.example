# ---------------------------------------------------------------------------
# Админка (Next.js)
# ---------------------------------------------------------------------------
# Учётка единственного администратора (проверяется на сервере).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# Секрет для подписи cookie-сессии (HMAC). Сгенерируй: openssl rand -base64 32
AUTH_SECRET=replace-with-long-random-string

# ---------------------------------------------------------------------------
# Self-hosted Supabase (уже крутится на Raspberry)
# Внутри общей docker-сети обращаемся к сервису kong по имени.
# ---------------------------------------------------------------------------
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# MQTT (Mosquitto)
# ---------------------------------------------------------------------------
# Из контейнера админки брокер доступен по имени сервиса.
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=backend
MQTT_PASSWORD=change-me-backend

# ---------------------------------------------------------------------------
# Node-RED → Supabase (используется во flow)
# ---------------------------------------------------------------------------
# REST endpoint PostgREST: обычно <SUPABASE_URL>/rest/v1
SUPABASE_REST=http://kong:8000/rest/v1

# ---------------------------------------------------------------------------
# Имя внешней docker-сети твоего Supabase-стека
# Проверь: docker network ls  (обычно supabase_default)
# ---------------------------------------------------------------------------
SUPABASE_NETWORK=supabase_default
