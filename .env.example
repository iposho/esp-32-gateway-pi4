# ---------------------------------------------------------------------------
# Self-hosted Supabase
# ---------------------------------------------------------------------------
# Серверный URL (внутри docker-сети)
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Публичный URL (доступный из браузера)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.kuzyak.in
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# MQTT (Mosquitto)
# ---------------------------------------------------------------------------
# Из контейнера админки брокер доступен по имени сервиса.
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=backend
MQTT_PASSWORD=change-me-backend

# ---------------------------------------------------------------------------
# Telegram резервный бот: Telegram ↔ MQTT bridge
# ---------------------------------------------------------------------------
# Создайте бота через @BotFather и укажите chat id владельца/группы.
TELEGRAM_BOT_TOKEN=123456:replace-with-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Алиас в Telegram → реальный MQTT device_id.
TELEGRAM_DEVICE_MAP=balcony:esp32-balcony,flat:esp32-flat,cam:esp32-cam
TELEGRAM_DEFAULT_DEVICE=balcony

# Отдельный MQTT-пользователь для Telegram bridge.
TELEGRAM_MQTT_USERNAME=telegram
TELEGRAM_MQTT_PASSWORD=change-me-telegram

# Через сколько секунд тишины считать online-устройство пропавшим
# и прислать предупреждение (0 — отключить проверку).
TELEGRAM_OFFLINE_TIMEOUT=120

# ---------------------------------------------------------------------------
# Публичный доступ к снимку камеры с других сайтов
# ---------------------------------------------------------------------------
# Query: ?token=... или заголовок Authorization: Bearer ...
CAMERA_API_TOKEN=change-me-camera-token

# ---------------------------------------------------------------------------
# Node-RED → Supabase (используется во flow)
# ---------------------------------------------------------------------------
# REST endpoint PostgREST: обычно <SUPABASE_URL>/rest/v1
SUPABASE_REST=http://kong:8000/rest/v1

# ---------------------------------------------------------------------------
# Имя внешней docker-сети твоего Supabase-стека
# Проверь: docker network ls  (обычно supabase_default)
# ---------------------------------------------------------------------------
SUPABASE_NETWORK=supabase_default
