# ACL для Mosquitto
#
# Топики проекта:
#   devices/<deviceId>/status        — публикует ESP32 (online/offline, LWT)
#   devices/<deviceId>/telemetry     — публикует ESP32 (метрики)
#   devices/<deviceId>/capabilities  — публикует ESP32 (описание команд для UI)
#   devices/<deviceId>/command       — публикует админка/Node-RED, читает ESP32

# --- Пользователь для устройств ESP32 ---
user esp32
topic write devices/+/status
topic write devices/+/telemetry
topic write devices/+/capabilities
topic read devices/+/command
# Межустройственные топики (например flat → out/flamingo, read чужой telemetry)
topic write devices/+/out/+
topic read devices/+/out/+
topic read devices/+/telemetry

# --- Пользователь для бэкенда (Node-RED + админка) ---
user backend
topic readwrite devices/#

# --- Резервный Telegram bridge ---
user telegram
topic read devices/+/status
topic read devices/+/telemetry
topic write devices/+/command

# --- Пользователь для отладки (только чтение) ---
user viewer
topic read devices/#
